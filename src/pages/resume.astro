---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Miguel Morales | Resume">

<main class="max-w-5xl mx-auto px-6 py-16">


<!-- Header -->

<section class="text-center mb-16">

<h1
class="
text-5xl
font-bold
text-rose
"
>
Miguel Morales
</h1>


<p
class="
mt-4
text-2xl
text-mauve
"
>
Software Engineer / Engineering Lead / Game Developer
</p>


<p
class="
mt-6
text-white/80
max-w-3xl
mx-auto
leading-relaxed
"
>
Software engineer specializing in Unity, C#, and gameplay systems.
Experienced building and shipping interactive products from concept
to production.
</p>


<div class="mt-8">

<a
href="/resume.pdf"
class="
bg-rose
text-midnight
font-bold
px-6
py-3
rounded-xl
hover:opacity-80
transition
"
>
Download Resume PDF
</a>

</div>

</section>



<!-- Skills -->

<section class="mb-16">


<h2
class="
text-3xl
font-bold
text-rose
mb-6
"
>
Technical Skills
</h2>


<div
class="
flex
flex-wrap
gap-3
"
>

{
[
"Unity",
"C#",
"Gameplay Programming",
"Mobile Development",
"Firebase",
"Analytics",
"LiveOps",
"Git",
"Software Architecture"
].map(skill => (

<span
class="
px-4
py-2
rounded-full
bg-purple/30
border
border-purple
"
>
{skill}
</span>

))
}

</div>


</section>


<br>

<!-- Experience -->

<section class="mb-16">


<h2
class="
text-3xl
font-bold
text-rose
mb-6
"
>
Experience
</h2>



<div
class="
bg-purple/20
border
border-purple
rounded-2xl
p-6
"
>


<h3
class="
text-2xl
font-bold
"
>
Software Engineer
</h3>


<p
class="
text-mauve
mt-1
"
>
Company Name · Location · Year - Present
</p>


<ul
class="
mt-5
space-y-3
text-white/80
list-disc
list-inside
"
>

<li>
Built and shipped gameplay systems using Unity and C#.
</li>

<li>
Designed scalable systems for progression, monetization,
and player engagement.
</li>

<li>
Collaborated across engineering, design, and product
to deliver production features.
</li>

</ul>


</div>


</section>


<br>

<!-- Selected Projects -->

<section class="mb-16">


<h2
class="
text-3xl
font-bold
text-rose
mb-6
"
>
Selected Projects
</h2>



<div
class="
space-y-6
"
>


<div
class="
bg-purple/20
border
border-purple
rounded-2xl
p-6
"
>

<h3
class="
text-2xl
font-bold
"
>
Word Puzzle Adventure
</h3>


<p
class="
text-mauve
mt-1
"
>
Unity · C# · Mobile
</p>


<p
class="
mt-4
text-white/80
"
>
Developed and shipped a mobile word game including
gameplay systems, progression, monetization, analytics,
and live features.
</p>

</div>



</div>


</section>


<br>

<!-- Education -->

<section>


<h2
class="
text-3xl
font-bold
text-rose
mb-6
"
>
Education
</h2>


<div
class="
bg-purple/20
border
border-purple
rounded-2xl
p-6
"
>

<h3 class="text-2xl font-bold">
Degree Name
</h3>

<p class="mt-2 text-white/80">
University Name · Year
</p>

</div>


</section>


</main>

</Layout>